  "components": {
    "schemas": {
      "ApplicationConfig": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "web_service"
            ],
            "properties": {
              "web_service": {
                "$ref": "#/components/schemas/WebServiceConfig"
              }
            }
          }
        ]
      },
      "ApplicationDetails": {
        "type": "object",
        "required": [
          "id",
          "app_type",
          "display_name",
          "deployments",
          "ingress",
          "monitor",
          "platform",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "app_type": {
            "$ref": "#/components/schemas/ApplicationType"
          },
          "created_at": {
            "type": "string"
          },
          "deployments": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "display_name": {
            "type": "string"
          },
          "id": {
            "$ref": "#/components/schemas/ApplicationId"
          },
          "ingress": {
            "$ref": "#/components/schemas/IngressConfig"
          },
          "monitor": {
            "$ref": "#/components/schemas/MonitorConfig"
          },
          "platform": {
            "$ref": "#/components/schemas/PlatformConfig"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "ApplicationGroup": {
        "type": "string",
        "enum": [
          "canary",
          "baseline"
        ]
      },
      "ApplicationId": {
        "type": "integer",
        "format": "int32",
        "minimum": 0
      },
      "ApplicationSummary": {
        "type": "object",
        "required": [
          "id",
          "app_type",
          "display_name",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "app_type": {
            "$ref": "#/components/schemas/ApplicationType"
          },
          "created_at": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "id": {
            "$ref": "#/components/schemas/ApplicationId"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "ApplicationType": {
        "type": "string",
        "description": "An identifier of what kind of application we're tracking.",
        "enum": [
          "web_service"
        ]
      },
      "CleartextPassword": {
        "type": "string"
      },
      "CreateApplicationRequest": {
        "type": "object",
        "required": [
          "display_name",
          "config"
        ],
        "properties": {
          "config": {
            "$ref": "#/components/schemas/ApplicationConfig"
          },
          "display_name": {
            "type": "string"
          }
        }
      },
      "CreateApplicationSuccess": {
        "type": "object",
        "required": [
          "application"
        ],
        "properties": {
          "application": {
            "$ref": "#/components/schemas/ApplicationSummary"
          }
        }
      },
      "CreateDeploymentSuccess": {
        "type": "object",
        "required": [
          "deployment"
        ],
        "properties": {
          "deployment": {
            "$ref": "#/components/schemas/Deployment"
          }
        }
      },
      "CreateResponseCodeMetricsRequest": {
        "type": "object",
        "required": [
          "app_group",
          "status_2xx_count",
          "status_4xx_count",
          "status_5xx_count"
        ],
        "properties": {
          "app_group": {
            "$ref": "#/components/schemas/ApplicationGroup"
          },
          "status_2xx_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "status_4xx_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "status_5xx_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "CreateResponseCodeMetricsSuccess": {
        "type": "object",
        "required": [
          "response_code_metrics"
        ],
        "properties": {
          "response_code_metrics": {
            "$ref": "#/components/schemas/ResponseCodeMetrics"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "description": "Expected body of user endpoint requests",
        "required": [
          "email",
          "password",
          "tos_accepted"
        ],
        "properties": {
          "email": {
            "$ref": "#/components/schemas/Email",
            "description": "String that may be invalid email address"
          },
          "password": {
            "$ref": "#/components/schemas/CleartextPassword",
            "description": "Password in cleartext, deserializes into more secure struct"
          },
          "tos_accepted": {
            "type": "boolean",
            "description": "Whether the user has accepted the terms of service"
          }
        }
      },
      "CreateUserSuccess": {
        "type": "object",
        "required": [
          "user"
        ],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserDetails"
