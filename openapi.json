  "components": {
    "schemas": {
      "ApplicationConfig": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "web_service"
            ],
            "properties": {
              "web_service": {
                "$ref": "#/components/schemas/WebServiceConfig"
              }
            }
          }
        ]
      },
      "ApplicationDetails": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "cloud": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Cloud"
              }
            ]
          },
          "created_at": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "id": {
            "$ref": "#/components/schemas/ApplicationId"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "ApplicationGroup": {
        "type": "string",
        "enum": [
          "canary",
          "baseline"
        ]
      },
      "ApplicationId": {
        "type": "integer",
        "format": "int32",
        "minimum": 0
      },
      "CleartextPassword": {
        "type": "string"
      },
      "Cloud": {
        "type": "string",
        "enum": [
          "Aws",
          "Cloudflare"
        ]
      },
      "CloudWatchDimensions": {
        "type": "object",
        "required": [
          "name",
          "value"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "CreateApplicationRequest": {
        "type": "object",
        "required": [
          "display_name"
        ],
        "properties": {
          "display_name": {
            "type": "string"
          }
        }
      },
      "CreateApplicationSuccess": {
        "type": "object",
        "required": [
          "application"
        ],
        "properties": {
          "application": {
            "$ref": "#/components/schemas/ApplicationDetails"
          }
        }
      },
      "CreateResponseCodeMetricsRequest": {
        "type": "object",
        "required": [
          "status_codes"
        ],
        "properties": {
          "status_codes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StatusCodeMetrics"
            }
          }
        }
      },
      "CreateResponseCodeMetricsSuccess": {
        "type": "object"
      },
      "CreateRolloutRequest": {
        "type": "object",
        "required": [
          "config"
        ],
        "properties": {
          "config": {
            "$ref": "#/components/schemas/ApplicationConfig"
          }
        }
      },
      "CreateRolloutSuccess": {
        "type": "object",
        "required": [
          "rollout"
        ],
        "properties": {
          "rollout": {
            "$ref": "#/components/schemas/Rollout"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "description": "Expected body of user endpoint requests",
        "required": [
          "email",
          "password",
          "tos_accepted"
        ],
        "properties": {
          "email": {
            "$ref": "#/components/schemas/Email",
            "description": "String that may be invalid email address"
          },
