    "/api/v1/heartbeat": {
      "get": {
        "tags": [
          "Heartbeat"
        ],
        "operationId": "heartbeat_controller",
        "responses": {
          "200": {
            "description": "Application is online and available",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "A Heartbeat response indicates the status of the server.\nIn almost every conceivable circumstance, the response should\nbe a success.",
                  "required": [
                    "ok"
                  ],
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/api/v1/users": {
      "post": {
        "tags": [
          "Users"
        ],
        "operationId": "Create User",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateUserSuccess"
                }
              }
            }
          },
          "422": {
            "description": "Create user failed due to invalid data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Create user failed due to internal error"
          }
        },
        "security": []
      }
    },
    "/api/v1/users/login": {
      "post": {
        "tags": [
